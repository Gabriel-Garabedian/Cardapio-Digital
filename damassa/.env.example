# ═══════════════════════════════════════════════
#  CONFIGURAÇÕES PARA PRODUÇÃO
# ═══════════════════════════════════════════════
# Copie este arquivo para .env e preencha os valores

# ⚠️ OBRIGATÓRIO — Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# WhatsApp do chef com DDI (somente dígitos)
# Ex: 5581999999999
CHEF_WHATSAPP=5581984552954

# ═══ LOCAL (SQLite) ═══
# Sem DATABASE_URL → usa SQLite automaticamente

# ═══ RENDER / PRODUÇÃO (PostgreSQL) ═══
# O Render define DATABASE_URL automaticamente no Environment
# Não precisa configurar manualmente
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Indica ambiente de produção (ativa session cookie secure)
PROD=1

# Para desenvolvimento local (descomente se precisar)
# FLASK_DEBUG=1
